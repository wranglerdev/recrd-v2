<Window x:Class="Recrd.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="recrd-agile-testing" Height="520" Width="860"
        WindowStartupLocation="CenterScreen">
    <!-- Tela inicial: chegar a uma automação em até 3 cliques (PRD §8, §19). -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="recrd-agile-testing"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />

        <!-- Widget: últimas execuções (PRD §8). -->
        <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
            <TextBlock DockPanel.Dock="Top" Text="Últimas execuções"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ListBox x:Name="ExecutionsList">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <TextBlock>
                                <Run Text="{Binding Icon}" /><Run Text=" " /><Run Text="{Binding Name}" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock Foreground="Gray" FontSize="11">
                                <Run Text="{Binding When}" /><Run Text="  ·  " /><Run Text="{Binding Duration}" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock x:Name="EmptyHint" Text="Nenhuma execução ainda."
                       Foreground="Gray" Visibility="Collapsed" />
        </DockPanel>

        <!-- Ações rápidas (PRD §8). -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="Ações rápidas" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
            <Button Content="Novo Projeto" Padding="0,10" Margin="0,4" Click="NovoProjeto_Click" />
            <Button Content="Gravar Novo Teste" Padding="0,10" Margin="0,4" Click="GravarTeste_Click" />
            <Button Content="Importar Massa" Padding="0,10" Margin="0,4" Click="ImportarMassa_Click" />
            <Button Content="Abrir Último Projeto" Padding="0,10" Margin="0,4" Click="AbrirUltimoProjeto_Click" />
            <Button Content="Sobre" Padding="0,10" Margin="0,20,0,0" Click="Sobre_Click" />
        </StackPanel>
    </Grid>
</Window>
