<Window x:Class="Recrd.App.AutomationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Automação — recrd" Height="640" Width="1040"
        WindowStartupLocation="CenterScreen">
    <!-- Tela de automação (PRD §9): header + sidebar + Browser Sandbox. -->
    <DockPanel>
        <!-- Header: barra de controles (PRD §9). -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="▶ Play" Click="Play_Click" />
            <Button Content="⏸ Pause" Click="Pause_Click" />
            <Button Content="⏹ Stop" Click="Stop_Click" />
            <Button Content="⟳ Reload" Click="Reload_Click" />
            <Separator />
            <Button Content="Exportar" Click="Exportar_Click" />
            <Button Content="Compilar" Click="Compilar_Click" />
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar (PRD §9): Timeline, Massas, Propriedades, Toggles, Element Inspector. -->
            <DockPanel Grid.Column="0" Margin="8">
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Toggles" FontWeight="SemiBold" Margin="0,8,0,4" />
                    <CheckBox x:Name="InspectToggle" Content="Modo Inspect" Margin="0,2" />
                </StackPanel>
                <TabControl>
                    <TabItem Header="Timeline">
                        <ListBox x:Name="Timeline" BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="Massas">
                        <ListBox x:Name="MassasList" BorderThickness="0" />
                    </TabItem>
                    <TabItem Header="Propriedades">
                        <TextBlock x:Name="Properties" TextWrapping="Wrap" Margin="4"
                                   Text="Selecione uma ação na Timeline." Foreground="Gray" />
                    </TabItem>
                    <TabItem Header="Inspector">
                        <TextBlock x:Name="Inspector" TextWrapping="Wrap" Margin="4"
                                   Text="Element Inspector." Foreground="Gray" />
                    </TabItem>
                </TabControl>
            </DockPanel>

            <!-- Browser Sandbox (PRD §10) — preenchido pela issue do sandbox. -->
            <Border Grid.Column="1" Margin="0,8,8,8" BorderBrush="#CCC" BorderThickness="1">
                <ContentControl x:Name="SandboxHost">
                    <TextBlock Text="Browser Sandbox" Foreground="Gray"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </ContentControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
